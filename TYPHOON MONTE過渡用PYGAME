    pygame.K_2: {"year": 2003, "name": "梅米 (Maemi)", "sst": 29.5, "shear": 8.0, "humid": 78.0, "lat": 15.0, "pres": 910.0},
    pygame.K_3: {"year": 2009, "name": "莫拉克 (Morakot)", "sst": 29.0, "shear": 15.0, "humid": 80.0, "lat": 23.0, "pres": 955.0},
    pygame.K_4: {"year": 2013, "name": "海燕 (Haiyan)", "sst": 29.8, "shear": 6.0, "humid": 76.0, "lat": 7.0, "pres": 895.0},
    pygame.K_5: {"year": 2015, "name": "蘇迪勒 (Soudelor)", "sst": 29.2, "shear": 10.0, "humid": 74.0, "lat": 14.0, "pres": 900.0},
    pygame.K_6: {"year": 2020, "name": "天鵝 (Goni)", "sst": 29.4, "shear": 8.0, "humid": 73.0, "lat": 16.0, "pres": 905.0},
    pygame.K_7: {"year": 2024, "name": "凱米 (Gaemi)", "sst": 28.8, "shear": 10.0, "humid": 79.0, "lat": 16.5, "pres": 940.0}
}

# 初始狀態
sim_state = {"sst": 27.5, "shear": 15.0, "humid": 75.0, "lat": 15.0, "pres": 1000.0}
hist_key = pygame.K_7 # 預設顯示凱米

# 暫存運算結果
points_sim, points_hist = [], []
prob_sim, prob_hist = 0.0, 0.0

# ================= 4. 核心運算函數 =================
def map_pixel(val, min_val, max_val, min_px, max_px):
    """將數值轉換為螢幕上的像素座標"""
    return int((val - min_val) / (max_val - min_val) * (max_px - min_px) + min_px)

def run_simulation(mean_sst, mean_shear, mean_humid, mean_lat, mean_pres, n=10000):
    """執行 10000 次蒙地卡羅抽樣，加入緯度與氣壓判斷"""
    points = []
    formed_count = 0
    
    # 使用 numpy 向量化運算加速
    s_arr = np.clip(np.random.normal(mean_sst, STD_SST, n), SST_MIN, SST_MAX)
    sh_arr = np.clip(np.random.normal(mean_shear, STD_SHEAR, n), SHEAR_MIN, SHEAR_MAX)
    h_arr = np.clip(np.random.normal(mean_humid, STD_HUMID, n), HUMID_MIN, HUMID_MAX)
    lat_arr = np.clip(np.random.normal(mean_lat, STD_LAT, n), LAT_MIN, LAT_MAX)
    pres_arr = np.clip(np.random.normal(mean_pres, STD_PRES, n), PRES_MIN, PRES_MAX)
    
    for i in range(n):
        # 嚴格的五變數物理門檻
        is_formed = (s_arr[i] > THRES_SST) and (sh_arr[i] < THRES_SHEAR) and \
                    (h_arr[i] > THRES_HUMID) and (lat_arr[i] > THRES_LAT) and \
                    (pres_arr[i] < THRES_PRES)
                    
        if is_formed:
            formed_count += 1
            
        points.append({"sst": s_arr[i], "shear": sh_arr[i], "formed": is_formed})
        
    return points, (formed_count / n) * 100

def update_data():
    global points_sim, prob_sim, points_hist, prob_hist
    points_sim, prob_sim = run_simulation(sim_state["sst"], sim_state["shear"], sim_state["humid"], sim_state["lat"], sim_state["pres"])
    
    hd = historical_db[hist_key]
    points_hist, prob_hist = run_simulation(hd["sst"], hd["shear"], hd["humid"], hd["lat"], hd["pres"])

# 啟動時先算一次
