            if event.key == pygame.K_w: sim_state["shear"] = min(SHEAR_MAX, sim_state["shear"] + 1.0); need_update = True
            if event.key == pygame.K_s: sim_state["shear"] = max(SHEAR_MIN, sim_state["shear"] - 1.0); need_update = True
            
            if event.key == pygame.K_e: sim_state["humid"] = min(HUMID_MAX, sim_state["humid"] + 2.0); need_update = True
            if event.key == pygame.K_q: sim_state["humid"] = max(HUMID_MIN, sim_state["humid"] - 2.0); need_update = True
            
            if event.key == pygame.K_f: sim_state["lat"] = min(LAT_MAX, sim_state["lat"] + 1.0); need_update = True
            if event.key == pygame.K_r: sim_state["lat"] = max(LAT_MIN, sim_state["lat"] - 1.0); need_update = True
            
            if event.key == pygame.K_g: sim_state["pres"] = min(PRES_MAX, sim_state["pres"] + 2.0); need_update = True
            if event.key == pygame.K_t: sim_state["pres"] = max(PRES_MIN, sim_state["pres"] - 2.0); need_update = True
            
            if event.key == pygame.K_SPACE: need_update = True

