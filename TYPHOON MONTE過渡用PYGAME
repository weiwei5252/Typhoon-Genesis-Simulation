        pygame.draw.line(screen, GRAY, (px_left + 20, PLOT_TOP), (px_left + 20, PLOT_BOTTOM), 2)
        
        sst_line_x = map_pixel(THRES_SST, SST_MIN, SST_MAX, px_left + 20, px_right)
