THRES_SST = 26.5
THRES_SHEAR = 20.0
THRES_HUMID = 70.0
THRES_LAT = 5.0      # 緯度需大於 5 度才有足夠科氏力
THRES_PRES = 1005.0  # 環境/初始氣壓需低於 1005 hPa

# 雜訊標準差 (常態分佈的隨機偏差)
STD_SST, STD_SHEAR, STD_HUMID = 0.6, 3.0, 5.0
STD_LAT, STD_PRES = 2.0, 4.0

# ================= 3. 資料庫設定 =================
historical_db = {
